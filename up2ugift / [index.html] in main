  { id:2, emoji:'👑', bg:'linear-gradient(135deg,#0a100a,#0d2010)', tag:'new', tagLabel:'جديد', cat:'congrats', occasion:'تهنئة ومناسبات', name:'تهنئة المدير/ة', desc:'شخصية تتحرك وتحتفل — مناسبة للترقيات', price:'9', btnLabel:'معاينة' },
  { id:3, emoji:'😂', bg:'linear-gradient(135deg,#0a0a1e,#1a1a3e)', tag:'', tagLabel:'', cat:'fun', occasion:'كوميدي وترفيه', name:'روستينج الصاحب', desc:'أربع شرائح كوميدية تضحكه وتدوّبه', price:'9', btnLabel:'معاينة' },
  { id:4, emoji:'⭐', bg:'linear-gradient(135deg,#0a0a10,#0d1020)', tag:'', tagLabel:'', cat:'friends', occasion:'أصدقاء وشكر', name:'شكر الصديقة', desc:'نجمة ذهبية تتفتح على رسالة شكر دافية', price:'9', btnLabel:'معاينة' },
  { id:5, emoji:'🌸', bg:'linear-gradient(135deg,#1a0a12,#2d0f20)', tag:'', tagLabel:'', cat:'love', occasion:'حب خفيف', name:'جواب البداية', desc:'للبدايات الحلوة — كلام خفيف ومؤثر', price:'9', btnLabel:'معاينة' },
  { id:6, emoji:'💌', bg:'linear-gradient(135deg,#1a0a20,#150525)', tag:'', tagLabel:'', cat:'love', occasion:'حب وعلاقات', name:'حب بعد سنة', desc:'هدية للعلاقات اللي لها تاريخ وذكريات', price:'9', btnLabel:'معاينة' },
  { id:7, emoji:'🎂', bg:'linear-gradient(135deg,#1a0a08,#2d1508)', tag:'new', tagLabel:'جديد', cat:'congrats', occasion:'أعياد ميلاد', name:'عيد الميلاد', desc:'كيكة تفاعلية تتفتح وتحتفل بيك', price:'9', btnLabel:'معاينة' },
  { id:8, emoji:'🕊️', bg:'linear-gradient(135deg,#080d0a,#0d1a10)', tag:'', tagLabel:'', cat:'friends', occasion:'مصالحة واعتذار', name:'رسالة صلح', desc:'باب يفتح على اعتذار صادق ودافي', price:'9', btnLabel:'معاينة' },
