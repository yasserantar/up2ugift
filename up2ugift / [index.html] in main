];

let currentFilter = 'all';
function renderGifts(filter) {
  const grid = document.getElementById('giftsGrid');
  const filtered = filter === 'all' ? gifts : gifts.filter(g => g.cat === filter);
  grid.innerHTML = filtered.map(g => `
    <div class="gift-card" data-id="${g.id}" data-cat="${g.cat}">
      <div class="gift-card-preview" style="background:${g.bg}">
        <span style="font-size:70px;z-index:1;position:relative">${g.emoji}</span>
        ${g.tag ? `<div class="gift-tag ${g.tag}">${g.tagLabel}</div>` : ''}
      </div>
      <div class="gift-info">
        <div class="gift-occasion ar-text">${g.occasion}</div>
        <div class="gift-name ar-text">${g.name}</div>
        <div class="gift-desc ar-text">${g.desc}</div>
        <div class="gift-footer">
          <div class="gift-price">$${g.price}<span> / هدية</span></div>
          <button class="gift-btn ar-text" onclick="openPreview(${g.id})">${g.btnLabel}</button>
        </div>
      </div>
    </div>
  `).join('');
}
renderGifts('all');

function filterGifts(cat) {
  currentFilter = cat;
  document.querySelectorAll('.filter-tab').forEach(t => t.classList.remove('active'));
  event.target.classList.add('active');
  renderGifts(cat);
}

// ── PREVIEW ──
function openPreview(id) {
  const gift = gifts.find(g => g.id === id);
  if(!gift) return;
  const overlay = document.getElementById('previewOverlay');
  const iframe = document.getElementById('previewIframe');
  const whatsappMsg = encodeURIComponent(`مرحبا، عايز أطلب هدية "${gift.name}" - باقة $${gift.price}`);
  document.getElementById('orderBtn').href = `https://wa.me/YOUR_NUMBER?text=${whatsappMsg}`;
  iframe.srcdoc = `<div style="width:100%;height:100%;background:${gift.bg};display:flex;align-items:center;justify-content:center;flex-direction:column;gap:20px;font-family:Tajawal,sans-serif;color:white;text-align:center;padding:40px;">
    <div style="font-size:80px">${gift.emoji}</div>
    <div style="font-size:24px;font-weight:700">${gift.name}</div>
    <div style="font-size:14px;opacity:.7;line-height:1.8;max-width:300px">${gift.desc}</div>
    <div style="margin-top:16px;padding:10px 24px;background:rgba(201,168,76,0.2);border:1px solid rgba(201,168,76,0.4);border-radius:100px;font-size:13px;color:#c9a84c">معاينة تجريبية — اطلب النسخة الكاملة</div>
  </div>`;
  overlay.classList.add('show');
  document.body.style.overflow = 'hidden';
}
function closePreview() {
  document.getElementById('previewOverlay').classList.remove('show');
  document.body.style.overflow = '';
}
document.getElementById('previewOverlay').addEventListener('click', function(e) {
  if(e.target === this) closePreview();
});

// ── ORDER PACKAGES ──
function orderPackage(pkg) {
  const msgs = {
    basic: 'عايز أطلب باقة الأساسية $9',
    pro: 'عايز أطلب باقة المميزة $19',
    premium: 'عايز أطلب باقة البريميوم $49'
  };
  window.open(`https://wa.me/YOUR_NUMBER?text=${encodeURIComponent(msgs[pkg])}`, '_blank');
}

// ── FORM ──
function submitForm(e) {
  e.preventDefault();
  const btn = e.target.querySelector('.form-submit');
  btn.textContent = '✓ تم الإرسال!';
  btn.style.background = 'linear-gradient(135deg,#065f46,#10b981)';
  setTimeout(() => {
    btn.textContent = '✦ ابعت الطلب';
    btn.style.background = '';
    e.target.reset();
  }, 3000);
}

// ── MOBILE NAV ──
function toggleMobileNav() {
  const links = document.querySelector('.nav-links');
  if(links.style.display === 'flex') {
    links.style.display = 'none';
  } else {
    links.style.cssText = 'display:flex;flex-direction:column;position:fixed;top:70px;left:0;right:0;background:rgba(12,10,8,0.98);padding:24px;gap:20px;z-index:99;border-bottom:1px solid rgba(201,168,76,0.2);';
  }
}
